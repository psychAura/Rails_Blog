

<%= form_with model: article do |form| %>
    <div>
        <%= form.label :title %></br>
        <%= form.text_field :title %>
        <!-- ##displays error in title if any. error comes from form vaidation defined in .models/article -->
        <% article.errors.full_messages_for(:title).each do |message| %>
            <div><%= message %></div>
        <% end %>
    </div>

    <div>
        <%= form.label :body %></br>
        <%= form.text_field :body %>
        <!-- ##displays error in body if any. error comes from form vaidation defined in .models/article -->
        <% article.errors.full_messages_for(:body).each do |message| %>
            <div><%= message %></div>
        <% end %>
    </div>

    <div>
        <%= form.submit %>
    </div>

<% end %>